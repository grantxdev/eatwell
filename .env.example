# Local dev: use a local Postgres URL (e.g. from Neon, Railway, or local Docker)
# On Vercel: these are set automatically when you add the Postgres integration
DATABASE_URL="postgres://..."
DIRECT_URL="postgres://..."

# Claude AI (required for meal suggestions)
ANTHROPIC_API_KEY="sk-ant-..."

# Vercel Blob (auto-set when you add the Blob integration on Vercel)
# Leave empty for local dev — uploads will save to public/uploads/ instead
BLOB_READ_WRITE_TOKEN=""
